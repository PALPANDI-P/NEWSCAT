# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=newscat-production-key-2024
HOST=127.0.0.1
PORT=5000

# Model Configuration
DEFAULT_CLASSIFIER=enhanced
MODEL_CACHE_DIR=data/models/pretrained
TRAINING_DATA_PATH=data/training/news_samples.json

# Text Processing
MIN_TEXT_LENGTH=20
MAX_TEXT_LENGTH=10000
MAX_WORDS=2000

# Feature Extraction
TFIDF_MAX_FEATURES=5000
NGRAM_RANGE=1,3
USE_LEMMATIZATION=True

# Performance
ENABLE_CACHING=True
CACHE_TIMEOUT=3600
WORKERS=4