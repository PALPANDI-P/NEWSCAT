{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/css/(.*)", "destination": "/frontend/css/$1" },
    { "source": "/js/(.*)", "destination": "/frontend/js/$1" },
    { "source": "/dashboard", "destination": "/frontend/index.html" },
    { "source": "/login", "destination": "/frontend/login.html" },
    { "source": "/(.*).html", "destination": "/frontend/$1.html" },
    { "source": "/", "destination": "/frontend/landing.html" }
  ]
}
